---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Kontakt – silniki-trojfazowe.pl"
  noindex={true}
>
  <style is:global slot="head">
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    :root { --navy:#1a2744; --blue:#2563eb; --surface:#f8f8f6; --border:#e8e8e4; --text:#1a1a1a; --muted:#8a8a8a; }
    .page-hero { background:linear-gradient(135deg,#1a2744,#243562); padding:40px 24px 36px; color:white; }
    .page-hero-inner { max-width:960px; margin:0 auto; }
    .page-hero-bc { font-size:12px; color:rgba(255,255,255,0.4); margin-bottom:10px; }
    .page-hero-bc a { color:rgba(255,255,255,0.45); text-decoration:none; }
    .page-hero-bc a:hover { color:white; }
    .page-hero h1 { font-size:26px; font-weight:800; letter-spacing:-0.4px; }
    .page-wrap { max-width:960px; margin:0 auto; padding:40px 24px 80px; display:grid; grid-template-columns:1fr 1fr; gap:32px; align-items:start; }
    @media(max-width:700px){ .page-wrap { grid-template-columns:1fr; } }

    .contact-card { background:white; border:1px solid var(--border); border-radius:18px; padding:28px 28px 24px; }
    .contact-card h2 { font-size:14px; font-weight:700; color:var(--text); letter-spacing:-0.2px; margin-bottom:20px; padding-bottom:12px; border-bottom:1px solid var(--border); }
    .contact-rows { display:flex; flex-direction:column; gap:14px; }
    .contact-row { display:flex; align-items:flex-start; gap:12px; }
    .contact-row-icon { width:34px; height:34px; background:#eef2ff; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .contact-row-icon svg { color:#2563eb; }
    .contact-row-label { font-size:10px; font-weight:600; letter-spacing:0.6px; text-transform:uppercase; color:var(--muted); margin-bottom:2px; }
    .contact-row-val { font-size:14px; font-weight:600; color:var(--text); line-height:1.4; }
    .contact-row-val a { color:var(--navy); text-decoration:none; }
    .contact-row-val a:hover { color:var(--blue); text-decoration:underline; }

    .map-card { background:white; border:1px solid var(--border); border-radius:18px; overflow:hidden; }
    .map-card iframe { display:block; width:100%; height:340px; border:none; }
    .map-card-footer { padding:14px 18px; font-size:12px; color:var(--muted); display:flex; align-items:center; gap:6px; }
  </style>

  <div class="page-hero">
    <div class="page-hero-inner">
      <div class="page-hero-bc"><a href="/">Strona główna</a> / Kontakt</div>
      <h1>Dane kontaktowe</h1>
    </div>
  </div>

  <div class="page-wrap">
    <div class="contact-card">
      <h2>Stojan S.C.</h2>
      <div class="contact-rows">
        <div class="contact-row">
          <div class="contact-row-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <div class="contact-row-label">Firma</div>
            <div class="contact-row-val">Stojan S.C. Adam Król, Włodzimierz Leszczyński</div>
          </div>
        </div>
        <div class="contact-row">
          <div class="contact-row-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.15a16 16 0 0 0 8 8l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 17z"/></svg>
          </div>
          <div>
            <div class="contact-row-label">Telefon</div>
            <div class="contact-row-val"><a href="tel:500385112">500 385 112</a></div>
          </div>
        </div>
        <div class="contact-row">
          <div class="contact-row-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <div class="contact-row-label">E-mail</div>
            <div class="contact-row-val"><a href="mailto:stojan@silniki-elektryczne.com.pl">stojan@silniki-elektryczne.com.pl</a></div>
          </div>
        </div>
        <div class="contact-row">
          <div class="contact-row-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="contact-row-label">Adres</div>
            <div class="contact-row-val">Wojewódzka 2<br/>87-152 Pigża</div>
          </div>
        </div>
        <div class="contact-row">
          <div class="contact-row-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
          </div>
          <div>
            <div class="contact-row-label">Dane rejestrowe</div>
            <div class="contact-row-val">NIP: 8790003705<br/>REGON: 870039184</div>
          </div>
        </div>
      </div>
    </div>

    <div class="map-card">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2399.6398967440397!2d18.519739715822915!3d53.10472098003061!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x470331a95853e26f%3A0x75a4abff339589ed!2sStojan s.c. A. Kr%C3%B3l W. Leszczy%C5%84ski!5e0!3m2!1spl!2spl!4v1706918723030!5m2!1spl!2spl"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Mapa dojazdu – Stojan S.C."
      ></iframe>
      <div class="map-card-footer">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Stojan S.C. · Wojewódzka 2, 87-152 Pigża
      </div>
    </div>
  </div>
</Layout>
