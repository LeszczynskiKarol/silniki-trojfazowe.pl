---
import Layout from '../layouts/Layout.astro';
import { fetchAllProducts } from '../lib/api.ts';

const products = await fetchAllProducts();
const total = products.length;

function normPow(val: any): number | null {
  if (val == null) return null;
  const s = String(val).replace(/kW/gi,'').replace(',','.').trim();
  const n = parseFloat(s);
  return isNaN(n) || n <= 0 ? null : n;
}

// Moce — 2+ produktów
const powCounts: Record<string, number> = {};
products.forEach((p: any) => {
  const n = normPow(p.power?.value);
  if (n !== null) {
    const key = n.toString();
    powCounts[key] = (powCounts[key]||0)+1;
  }
});
const popularPowers = Object.entries(powCounts)
  .filter(([, cnt]) => cnt >= 2)
  .sort((a, b) => Number(a[0]) - Number(b[0]))
  .map(([kw, cnt]) => ({
    kw: Number(kw), cnt,
    slug: kw.replace('.', '-') + 'kw',
    label: Number(kw).toString().replace('.', ',')
  }));

// Stan produktów (do filtra)
const CONDITIONS = [
  { value: '', label: 'Wszystkie' },
  { value: 'uzywany', label: 'Używane' },
  { value: 'nowy', label: 'Nowe' },
  { value: 'nieuzywany', label: 'Nieużywane' },
];
const condCounts: Record<string, number> = { '': total };
products.forEach((p: any) => {
  condCounts[p.condition] = (condCounts[p.condition]||0)+1;
});

const PER_PAGE = 24;
const firstPageProducts = products.slice(0, PER_PAGE);

function cap(s: string): string {
  return s ? s.charAt(0).toUpperCase() + s.slice(1) : s;
}

const COND_LABEL: Record<string, string> = { nowy: 'Nowy', uzywany: 'Używany', nieuzywany: 'Nieużywany' };
---
<Layout
  title="Silniki trójfazowe – nowe i używane | silniki-trojfazowe.pl"
  description={`Sklep z silnikami trójfazowymi. ${total} silników w ofercie — nowe, używane i magazynowe. Wysyłka kurierem 2–4 dni.`}
  canonical="https://www.silniki-trojfazowe.pl/"
>
  <style is:global slot="head">
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    :root { --navy:#1a2744; --navy2:#243562; --blue:#2563eb; --surface:#f8f8f6; --border:#e8e8e4; --text:#1a1a1a; --muted:#8a8a8a; }
    .hero { background:linear-gradient(135deg,#1a2744 0%,#243562 100%); padding:52px 24px 48px; text-align:center; color:white; }
    .hero h1 { font-size:32px; font-weight:800; letter-spacing:-0.6px; margin-bottom:10px; line-height:1.2; }
    @media(max-width:600px){ .hero h1 { font-size:22px; } }
    .hero-sub { font-size:14px; color:rgba(255,255,255,0.55); margin-bottom:28px; }
    .hero-stats { display:inline-flex; gap:32px; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.12); border-radius:14px; padding:14px 28px; }
    @media(max-width:500px){ .hero-stats { gap:16px; padding:12px 16px; } }
    .hero-stat-val { font-size:22px; font-weight:800; color:white; font-family:'DM Mono',monospace; }
    .hero-stat-lab { font-size:10px; color:rgba(255,255,255,0.5); text-transform:uppercase; letter-spacing:0.8px; margin-top:2px; }
    .section { max-width:1280px; margin:0 auto; padding:40px 24px 0; }
    .section-title { font-size:18px; font-weight:800; color:var(--text); letter-spacing:-0.3px; margin-bottom:16px; }
    .pow-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(90px,1fr)); gap:8px; }
    .pow-tile { background:white; border:1.5px solid var(--border); border-radius:12px; padding:14px 8px; text-decoration:none; text-align:center; transition:all 0.15s; display:block; }
    .pow-tile:hover { border-color:var(--navy); background:#f0f3ff; }
    .pow-val { font-size:17px; font-weight:800; color:var(--navy); font-family:'DM Mono',monospace; display:block; }
    .pow-unit { font-size:11px; color:var(--muted); }
    .pow-cnt { font-size:10px; color:var(--blue); font-weight:600; margin-top:3px; display:block; }
    .catalog-wrap { max-width:1280px; margin:0 auto; padding:36px 24px 80px; display:grid; grid-template-columns:220px 1fr; gap:28px; align-items:start; }
    @media(max-width:860px){ .catalog-wrap { grid-template-columns:1fr; } }
    .sidebar { position:sticky; top:76px; display:flex; flex-direction:column; gap:14px; }
    @media(max-width:860px){ .sidebar { position:static; } }
    .fbox { background:white; border:1px solid var(--border); border-radius:14px; padding:16px 18px; }
    .ftitle { font-size:10px; font-weight:700; letter-spacing:1px; text-transform:uppercase; color:var(--muted); margin-bottom:10px; }
    .flist { display:flex; flex-direction:column; gap:2px; }
    .fcat { display:flex; align-items:center; justify-content:space-between; padding:8px 10px; border-radius:8px; cursor:pointer; font-size:13px; font-weight:500; color:var(--text); border:none; background:none; width:100%; text-align:left; transition:background 0.1s; }
    .fcat:hover { background:#f5f5f3; }
    .fcat.on { background:#eef2ff; color:var(--navy); font-weight:700; }
    .fcat .cnt { font-size:11px; color:var(--muted); background:#f0f0ee; padding:2px 7px; border-radius:10px; flex-shrink:0; }
    .fcat.on .cnt { background:#dde4ff; color:var(--navy); }
    .pgrid-pow { display:grid; grid-template-columns:repeat(3,1fr); gap:5px; }
    .pbtn { padding:7px 4px; border-radius:7px; border:1.5px solid var(--border); background:white; font-size:11px; font-weight:600; cursor:pointer; color:var(--text); transition:all 0.12s; text-align:center; font-family:'Sora',sans-serif; white-space:nowrap; }
    .pbtn:hover { border-color:var(--blue); color:var(--blue); }
    .pbtn.on { border-color:var(--navy); background:var(--navy); color:white; }
    .clrbtn { width:100%; padding:9px; border-radius:8px; border:1.5px solid var(--border); background:none; font-size:12px; font-weight:600; cursor:pointer; color:var(--muted); font-family:'Sora',sans-serif; transition:all 0.15s; }
    .clrbtn:hover { border-color:#ef4444; color:#ef4444; }
    .rhead { display:flex; align-items:center; justify-content:space-between; margin-bottom:18px; flex-wrap:wrap; gap:8px; }
    .rcnt { font-size:13px; color:var(--muted); }
    .tags { display:flex; gap:6px; flex-wrap:wrap; }
    .tag { display:inline-flex; align-items:center; gap:5px; padding:4px 10px 4px 12px; background:#eef2ff; color:var(--navy); border-radius:20px; font-size:12px; font-weight:600; }
    .tag button { background:none; border:none; cursor:pointer; color:var(--navy); font-size:16px; line-height:1; padding:0 0 0 2px; opacity:0.5; }
    .tag button:hover { opacity:1; }
    .pgrid-products { display:grid; grid-template-columns:repeat(auto-fill,minmax(190px,1fr)); gap:14px; }
    .card { background:white; border-radius:14px; border:1px solid var(--border); overflow:hidden; text-decoration:none; color:inherit; display:flex; flex-direction:column; transition:box-shadow 0.18s,transform 0.18s; }
    .card:hover { box-shadow:0 8px 28px rgba(0,0,0,0.1); transform:translateY(-2px); }
    .card-img { aspect-ratio:1; background:#f7f7f5; overflow:hidden; display:flex; align-items:center; justify-content:center; padding:12px; }
    .card-img img { max-width:100%; max-height:100%; object-fit:contain; transition:transform 0.3s; }
    .card:hover .card-img img { transform:scale(1.06); }
    .card-body { padding:12px 14px 14px; display:flex; flex-direction:column; gap:4px; flex:1; }
    .card-mfr { font-size:10px; font-weight:700; letter-spacing:0.8px; text-transform:uppercase; color:var(--muted); }
    .card-name { font-size:12px; font-weight:600; line-height:1.45; color:var(--text); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; flex:1; }
    .card-specs { font-size:11px; color:var(--muted); font-family:'DM Mono',monospace; margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .card-bottom { display:flex; align-items:center; justify-content:space-between; margin-top:8px; padding-top:8px; border-top:1px solid #f0f0ee; }
    .card-price { font-size:16px; font-weight:800; color:var(--navy); font-family:'DM Mono',monospace; }
    .card-badge { font-size:10px; font-weight:600; padding:3px 8px; border-radius:20px; white-space:nowrap; }
    .card-badge.dostepny { background:#dcfce7; color:#16a34a; }
    .card-badge.nowy { background:#dbeafe; color:#2563eb; }
    .card-badge.uzywany { background:#dcfce7; color:#16a34a; }
    .card-badge.nieuzywany { background:#fef3c7; color:#d97706; }
    .nores { text-align:center; padding:80px 20px; color:var(--muted); font-size:15px; grid-column:1/-1; }
    .pg { display:flex; justify-content:center; align-items:center; gap:6px; margin-top:36px; flex-wrap:wrap; }
    .pg-btn { min-width:38px; height:38px; padding:0 10px; border-radius:10px; border:1.5px solid var(--border); background:white; color:var(--text); font-size:13px; font-weight:600; cursor:pointer; transition:all 0.15s; font-family:'Sora',sans-serif; display:inline-flex; align-items:center; justify-content:center; }
    .pg-btn:hover:not(:disabled) { border-color:var(--navy); color:var(--navy); }
    .pg-btn.on { border-color:var(--navy); background:var(--navy); color:white; }
    .pg-btn:disabled { opacity:0.35; cursor:default; }
    .pg-dots { color:var(--muted); padding:0 4px; }
    .seo-section { background:white; border-top:1px solid var(--border); padding:56px 24px; }
    .seo-inner { max-width:960px; margin:0 auto; }
    .seo-inner h2 { font-size:20px; font-weight:800; color:var(--text); margin-bottom:14px; letter-spacing:-0.3px; }
    .seo-inner h3 { font-size:14px; font-weight:700; color:var(--text); margin:24px 0 8px; }
    .seo-inner p { font-size:14px; line-height:1.8; color:#555; margin-bottom:10px; }
    .seo-cols { display:grid; grid-template-columns:1fr 1fr; gap:32px; }
    @media(max-width:640px){ .seo-cols { grid-template-columns:1fr; } }
    .seo-list { list-style:none; display:flex; flex-direction:column; gap:7px; }
    .seo-list li { display:flex; gap:8px; font-size:13px; color:#555; line-height:1.5; }
    .seo-list li::before { content:'✓'; color:#16a34a; font-weight:700; flex-shrink:0; }
  </style>

  <section class="hero">
    <h1>Silniki trójfazowe <br>nowe i używane</h1>
    <p class="hero-sub">Trójfazowe 230/400V · 400/690V · IE1 · IE2 · IE3</p>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-val">{total}</div>
        <div class="hero-stat-lab">Silników</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-val">2–4</div>
        <div class="hero-stat-lab">Dni wysyłki</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-val">25</div>
        <div class="hero-stat-lab">lat na rynku</div>
      </div>
    </div>
  </section>

  {popularPowers.length > 0 && (
    <div class="section">
      <h2 class="section-title">Popularne moce</h2>
      <div class="pow-grid">
        {popularPowers.map(pw => (
          <a href={`/moc/${pw.slug}`} class="pow-tile">
            <span class="pow-val">{pw.label}</span>
            <span class="pow-unit">kW</span>
            <span class="pow-cnt">{pw.cnt} szt.</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="catalog-wrap" id="katalog">
    <aside class="sidebar">
      <div class="fbox">
        <div class="ftitle">Stan</div>
        <div class="flist" id="cond-list">
          {CONDITIONS.map(c => (
            <button class={`fcat${c.value === '' ? ' on' : ''}`} data-cond={c.value}>
              {c.label} <span class="cnt" id={`cnt-cond-${c.value || 'all'}`}>{condCounts[c.value] || 0}</span>
            </button>
          ))}
        </div>
      </div>
      <div class="fbox">
        <div class="ftitle">Moc (kW)</div>
        <div class="pgrid-pow" id="pow-grid">
          {popularPowers.map(pw => (
            <button class="pbtn" data-pow={pw.kw}>{pw.label}</button>
          ))}
        </div>
      </div>
      <button class="clrbtn" id="clr">✕ Wyczyść filtry</button>
    </aside>

    <main>
      <div class="rhead">
        <span class="rcnt" id="rcnt">{total} produktów</span>
        <div class="tags" id="tags"></div>
      </div>
      <div class="pgrid-products" id="grid">
        {firstPageProducts.map((p: any) => {
          const pSlug = p.marketplaces?.ownStore?.slug;
          const pImg = p.mainImage || p.images?.[0] || '/placeholder.webp';
          const pPrice = Number(p.marketplaces?.ownStore?.price ?? p.price);
          const pName = cap(p.name);
          const pw = p.power?.value;
          const pSpecs = [pw && `${pw} kW`, p.rpm?.value && `${p.rpm.value} obr/min`, p.weight && `${p.weight} kg`].filter(Boolean).join(' · ');
          const condLabel = COND_LABEL[p.condition] || p.condition;
          return (
            <a href={`/silnik/${pSlug}`} class="card">
              <div class="card-img"><img src={pImg} alt={pName} loading="lazy" /></div>
              <div class="card-body">
                {p.manufacturer && <div class="card-mfr">{p.manufacturer}</div>}
                <div class="card-name">{pName}</div>
                {pSpecs && <div class="card-specs">{pSpecs}</div>}
                <div class="card-bottom">
                  <span class="card-price">{pPrice.toLocaleString('pl-PL')} zł</span>
                  <span class={`card-badge ${p.condition}`}>{condLabel}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
      <div class="pg" id="pg"></div>
    </main>
  </div>

  <section class="seo-section">
    <div class="seo-inner">
      <h2>Sklep z silnikami trójfazowymi</h2>
      <p>Oferujemy <strong>silniki trójfazowe</strong> — nowe, używane i magazynowe — sprawdzone pod kątem stanu technicznego. Wszystkie napędy dostarcza firma <a href="https://www.silniki-elektryczne.com.pl/trojfazowe" style="text-decoration:underline;">Stojan Silniki Elektryczne</a>.</p>
      <div class="seo-cols">
        <div>
          <h3>Dlaczego warto kupić u nas?</h3>
          <ul class="seo-list">
            <li>Zweryfikowany stan techniczny każdego silnika</li>
            <li>Wysyłka kurierem – 2–4 dni robocze</li>
            <li>Płatność online (BLIK, karta, przelew) lub za pobraniem</li>
            <li>14 dni na zwrot towaru</li>
            <li>Faktury VAT dla firm</li>
            <li>Moce od 0,09 kW do 200 kW</li>
          </ul>
        </div>
        <div>
          <h3>Parametry silników trójfazowych</h3>
          <ul class="seo-list">
            <li>Napięcie 230/400V i 400/690V</li>
            <li>Prędkości: 700, 900, 1400, 2900 obr/min</li>
            <li>Klasy sprawności IE1, IE2, IE3</li>
            <li>Marki: Siemens, ABB, SEW, Indukta, Tamel</li>
            <li>Wielkości mechaniczne od 56 do 315</li>
            <li>Wykonania: B3 (łapowe), B5 (kołnierzowe), B35</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context":"https://schema.org","@type":"Store",
    "name":"silniki-trojfazowe.pl","url":"https://www.silniki-trojfazowe.pl",
    "description":`Sklep z silnikami trójfazowymi. ${total} silników w ofercie.`,
    "offers":{"@type":"AggregateOffer","offerCount":total}
  })} />

  <script define:vars={{ products, popularPowers, CONDITIONS, condCounts }}>
    const PER = 24;
    const COND_LABEL = { nowy:'Nowy', uzywany:'Używany', nieuzywany:'Nieużywany' };
    let cond = '', pow = null, page = 1;

    const u = new URLSearchParams(location.search);
    if (u.get('stan')) cond = u.get('stan');
    if (u.get('moc')) pow = parseFloat(u.get('moc'));
    if (u.get('s')) page = parseInt(u.get('s')) || 1;

    const cap = s => s ? s.charAt(0).toUpperCase() + s.slice(1) : s;
    const matchCond = (p, c) => !c || p.condition === c;
    const matchPow = (p, pw) => pw === null || (p.power?.value != null && Math.abs(p.power.value - pw) < 0.01);
    const visible = () => products.filter(p => matchCond(p, cond) && matchPow(p, pow));

    function scrollToCatalog() {
      const el = document.getElementById('katalog');
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function render() {
      const list = visible();
      const pages = Math.ceil(list.length / PER) || 1;
      if (page > pages) page = 1;
      const slice = list.slice((page-1)*PER, page*PER);

      document.getElementById('rcnt').textContent =
        `${list.length} ${list.length===1?'produkt':list.length<5?'produkty':'produktów'}`;

      const tagsEl = document.getElementById('tags');
      tagsEl.innerHTML = '';
      if (cond) {
        const label = COND_LABEL[cond] || cond;
        const t = document.createElement('span'); t.className='tag';
        t.innerHTML = `${label} <button onclick="clrCond()">×</button>`;
        tagsEl.appendChild(t);
      }
      if (pow !== null) {
        const t = document.createElement('span'); t.className='tag';
        t.innerHTML = `${pow.toString().replace('.',',')} kW <button onclick="clrPow()">×</button>`;
        tagsEl.appendChild(t);
      }

      const grid = document.getElementById('grid');
      grid.innerHTML = !slice.length
        ? '<p class="nores">Brak produktów dla wybranych filtrów</p>'
        : slice.map(p => {
            const slug = p.marketplaces?.ownStore?.slug;
            const img = p.mainImage || p.images?.[0] || '/placeholder.webp';
            const price = Number(p.marketplaces?.ownStore?.price ?? p.price);
            const pw = p.power?.value;
            const specs = [pw && `${pw} kW`, p.rpm?.value && `${p.rpm.value} obr/min`, p.weight && `${p.weight} kg`].filter(Boolean).join(' · ');
            const name = cap(p.name);
            const condL = COND_LABEL[p.condition] || p.condition;
            return `<a href="/silnik/${slug}" class="card">
              <div class="card-img"><img src="${img}" alt="${name}" loading="lazy"></div>
              <div class="card-body">
                ${p.manufacturer?`<div class="card-mfr">${p.manufacturer}</div>`:''}
                <div class="card-name">${name}</div>
                ${specs?`<div class="card-specs">${specs}</div>`:''}
                <div class="card-bottom">
                  <span class="card-price">${price.toLocaleString('pl-PL')} zł</span>
                  <span class="card-badge ${p.condition}">${condL}</span>
                </div>
              </div>
            </a>`;
          }).join('');

      const pgEl = document.getElementById('pg');
      if (pages <= 1) { pgEl.innerHTML=''; } else {
        let h = `<button class="pg-btn" onclick="goP(${page-1})" ${page===1?'disabled':''}>‹</button>`;
        for (let i=1; i<=pages; i++) {
          if (pages>8 && i!==1 && i!==pages && Math.abs(i-page)>2) {
            if (i===page-3||i===page+3) h+='<span class="pg-dots">…</span>';
            continue;
          }
          h+=`<button class="pg-btn${i===page?' on':''}" onclick="goP(${i})">${i}</button>`;
        }
        h+=`<button class="pg-btn" onclick="goP(${page+1})" ${page===pages?'disabled':''}>›</button>`;
        pgEl.innerHTML=h;
      }

      document.querySelectorAll('[data-cond]').forEach(b => b.classList.toggle('on', b.dataset.cond===cond));
      document.querySelectorAll('[data-pow]').forEach(b =>
        b.classList.toggle('on', pow!==null && Math.abs(parseFloat(b.dataset.pow)-pow)<0.01)
      );

      const p2 = new URLSearchParams();
      if (cond) p2.set('stan',cond);
      if (pow!==null) p2.set('moc',pow);
      if (page>1) p2.set('s',page);
      history.replaceState(null,'', p2.toString() ? '?'+p2 : '/');
    }

    window.goP = p => { page=p; render(); scrollToCatalog(); };
    window.clrCond = () => { cond=''; page=1; render(); };
    window.clrPow = () => { pow=null; page=1; render(); };

    document.getElementById('cond-list').addEventListener('click', e => {
      const b = e.target.closest('[data-cond]'); if (!b) return;
      cond=b.dataset.cond; page=1; render(); scrollToCatalog();
    });
    document.getElementById('pow-grid').addEventListener('click', e => {
      const b = e.target.closest('[data-pow]'); if (!b) return;
      const v = parseFloat(b.dataset.pow);
      pow = (pow!==null && Math.abs(pow-v)<0.01) ? null : v;
      page=1; render();
    });
    document.getElementById('clr').addEventListener('click', () => {
      cond=''; pow=null; page=1; render();
    });

    render();
  </script>
</Layout>